# Database — PostgreSQL connection string
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/dalla_deal_tracker

# Auth — JWT signing key (generate with: openssl rand -hex 32)
SECRET_KEY=your-secret-key-here-change-in-production

# OTP — HMAC secret for generating time-based OTPs
OTP_SECRET=your-otp-secret-here

# JWT token validity (in minutes) — default 7 days
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Dev mode — set to false in production (bypasses OTP verification)
DEV_MODE=true

# MSG91 — SMS OTP provider (required when DEV_MODE=false)
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=

# AWS S3 — file storage (leave empty to use local disk)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=dalla-photos
AWS_REGION=ap-south-1

# Firebase Cloud Messaging (FCM server key for push notifications)
FCM_SERVER_KEY=

# Sentry — error tracking (leave empty to disable)
SENTRY_DSN=

# CORS — comma-separated allowed origins (use * for dev)
CORS_ORIGINS=*

# Redis — caching and background jobs (leave empty to disable)
REDIS_URL=redis://localhost:6379/0
