# Database — local PostgreSQL (user: yash, db: dalla_deal_tracker)
DATABASE_URL=postgresql+asyncpg://yash:3139@localhost:5432/dalla_deal_tracker

# Auth — JWT signing key (keep secret in production)
SECRET_KEY=1ae348fc368039222b52210b44790f11a918711b0905882aaeaa2fd3243a578b

# OTP — HMAC secret for generating time-based OTPs
OTP_SECRET=e334c8c4ed46ca0c207b5f0849e3d1b5

# JWT token validity (in minutes) — default 7 days
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Dev mode — bypasses OTP, uses local file storage
DEV_MODE=true

# MSG91 — SMS OTP (leave empty for dev)
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=

# AWS S3 — for photo proof storage (leave empty for local disk)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=dalla-photos
AWS_REGION=ap-south-1

# WhatsApp (Meta Cloud API)
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=

# Firebase Cloud Messaging (FCM server key for push notifications)
FCM_SERVER_KEY=

# Sentry — error tracking (leave empty to disable)
SENTRY_DSN=

# CORS — allowed origins
CORS_ORIGINS=*

# Redis — caching and background jobs (leave empty to disable)
REDIS_URL=redis://localhost:6379/0
